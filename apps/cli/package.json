{
  "name": "@tanky/cli",
  "version": "0.0.0-development",
  "type": "module",
  "description": "CLI to retrieve nearby fuel prices from public datasets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleixalonso/tanky"
  },
  "homepage": "https://github.com/aleixalonso/tanky#readme",
  "bugs": {
    "url": "https://github.com/aleixalonso/tanky/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "tanky": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "lint": "biome check src",
    "test": "vitest run",
    "cli": "node ./dist/index.js"
  },
  "dependencies": {
    "@tanky/core": "workspace:*",
    "@tanky/provider-es": "workspace:*",
    "@tanky/types": "workspace:*",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0"
  }
}
