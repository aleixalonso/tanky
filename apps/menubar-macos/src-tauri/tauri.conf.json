{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tanky Menubar",
  "version": "0.1.0",
  "identifier": "com.tanky.menubar",
  "build": {
    "beforeDevCommand": "pnpm vite dev",
    "beforeBuildCommand": "pnpm vite build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tanky",
        "width": 400,
        "height": 620,
        "visible": false,
        "resizable": false,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "macOS": {
      "infoPlist": "./Info.plist"
    },
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
